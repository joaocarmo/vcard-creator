{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "types": ["node"],
    "outDir": "dist/cjs",
    "rootDir": "lib"
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["lib/**/*.test.ts"]
}
