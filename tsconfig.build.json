{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "lib"
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["lib/**/*.test.ts"]
}
