{
  "name": "vcard-creator",
  "version": "0.9.0",
  "description": "A JavaScript vCard creator library for both node.js and the web",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "types": "./dist/types/index.d.ts",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:umd": "NODE_ENV=production webpack --mode production",
    "build": "pnpm clean && pnpm build:cjs && pnpm build:esm && pnpm build:types && pnpm build:umd",
    "clean": "rimraf ./dist/ ./node_modules/.cache/ *.vcf *.ics",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "prepare": "husky",
    "pretty:fix": "prettier --write .",
    "pretty": "prettier --check .",
    "test:esm": "node ./test-functional/test-vcard.mjs",
    "test:functional": "(./test-functional/test-vcard.js | tee vcard.vcf) && pnpm test:esm && (./test-functional/test-vcalendar.js 2>/dev/null | tee vcard.ics)",
    "test:unit": "jest",
    "test:web-build": "NODE_ENV=development webpack --mode development && open ./test-functional/test-build.html",
    "test:web-export": "open ./test-functional/test-export.html",
    "type-check:watch": "pnpm type-check --watch",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaocarmo/vcard-creator.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "tag": "latest"
  },
  "keywords": [
    "vcard",
    "node",
    "browser"
  ],
  "author": "Joao Carmo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joaocarmo/vcard-creator/issues"
  },
  "homepage": "https://github.com/joaocarmo/vcard-creator#readme",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-date-mock": "^1.0.10",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
